APP_NAME="Shueki Tech"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://shuekitech.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ─── Database ───────────────────────────────────────────
# LOCAL: SQLite (no setup needed)
DB_CONNECTION=sqlite

# PRODUCTION (Hostinger): uncomment and fill in
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=your_db_name
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password

# ─── Session ────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Cache & Queue ──────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ─── Mail (Gmail SMTP) ──────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@shuekitech.com
MAIL_PASSWORD=your_hostinger_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@shuekitech.com"
MAIL_FROM_NAME="Shueki Tech"

# ─── CORS / Sanctum ─────────────────────────────────────
# LOCAL: comma-separated list of frontend origins
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173,127.0.0.1:3000,127.0.0.1:5173
# PRODUCTION: SANCTUM_STATEFUL_DOMAINS=shuekitech.com,www.shuekitech.com

# ─── Admin ──────────────────────────────────────────────
ADMIN_NAME="Admin"
ADMIN_EMAIL=admin@shuekitech.com
ADMIN_PASSWORD=change_this_password

# Email address that receives enquiry notifications
ADMIN_NOTIFICATION_EMAIL=info@shuekitech.com
